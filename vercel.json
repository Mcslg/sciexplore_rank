{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "style.css", "use": "@vercel/static" },
    { "src": "ranking.js", "use": "@vercel/static" },
    { "src": "icon.png", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/favicon.ico", "destination": "/icon.png" },
    { "source": "/api/proxy", "destination": "api/proxy.js" },
    { "source": "/api/track", "destination": "api/track.js" },
    { "source": "/api/compact", "destination": "api/compact.js" },
    { "source": "/api/history", "destination": "api/history.js" }
  ]
}
